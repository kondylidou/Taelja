% Regression test for prelemmatize symmetric equation lookup.
% Axiom 2 derives the equation h(a) = k(a) as a derived unit.
% Axiom 3's body contains k(a) = h(a) (the symmetric form).
% With the fix, prelemmatize finds the derived unit via Map.lookup of Eq(k(a),h(a))
% and names it as a lemma before processing, so it is cited by name in the proof
% rather than being inlined a second time.
fof(f1,axiom,(
  h(a) = k(a)),
  file('test',unknown)).
fof(f2,axiom,(
  ! [X0] : ((h(X0) = k(X0)) => p(X0))),
  file('test',unknown)).
fof(f3,axiom,(
  ! [X0] : ((k(X0) = h(X0)) => q(X0))),
  file('test',unknown)).
fof(f4,axiom,(
  ! [X0] : ((p(X0) & q(X0)) => r(X0))),
  file('test',unknown)).
fof(f5,conjecture,(
  r(a)),
  file('test',unknown)).
fof(f6,negated_conjecture,(
  ~r(a)),
  inference(negated_conjecture,[status(cth)],[f5])).
